DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=1502588698246778960

# Gemma/Gemini API keys.
# Use one key, or comma-separated keys for fallback rotation.
GEMINI_API_KEYS=your_gemini_api_key_here

# Main text model and fallback text models.
GEMMA_MODEL=gemma-4-26b-a4b-it
GEMMA_FALLBACK_MODELS=gemma-4-31b-it

# Vision model for image prompts.
GEMINI_VISION_MODEL=gemini-2.5-flash-lite
GEMINI_VISION_FALLBACK_MODELS=gemini-2.5-flash

# Optional Discord command cleanup target.
# If set, npm run register clears server-only commands here to avoid duplicates.
GUILD_ID=

# Optional runtime settings.
PORT=8080
TETRIO_LEAGUE_DATA_DIR=
GEMINI_TIMEOUT_MS=20000
GEMINI_MAX_OUTPUT_TOKENS=1024
GEMINI_MAX_ATTEMPTS_PER_MODEL=3
GEMINI_TIMING_LOGS=true
GEMINI_MEMORY_DAYS=365
GEMINI_MEMORY_MAX_MESSAGES_PER_SESSION=30
GEMINI_MEMORY_MAX_ENTRY_LENGTH=1800
GEMINI_MEMORY_MAX_CONTEXT_LENGTH=12000
GEMINI_IMAGE_MAX_BYTES=8388608

# Optional chess image recognition and Stockfish settings.
CHESS_IMAGE_PYTHON=
CHESS_IMAGE_TIMEOUT_MS=120000
CHESS_IMAGE_MAX_BYTES=8388608
CHESS_IMAGE_MIN_CONFIDENCE=0
CHESS_STOCKFISH_MOVETIME_MS=2000

# Optional Lichess opening-book settings for bot-vs-user chess play.
CHESS_OPENING_ENABLED=true
CHESS_OPENING_PLAYER=bears4347
CHESS_OPENING_SPEEDS=blitz,rapid,classical
CHESS_OPENING_MODES=rated
CHESS_OPENING_MAX_PLY=18
CHESS_OPENING_MIN_GAMES=2
CHESS_OPENING_STYLE=mimic
CHESS_OPENING_NETWORK_ENABLED=false
CHESS_OPENING_TIMEOUT_MS=3500
CHESS_OPENING_PRELOAD_MAX_NODES=250
CHESS_OPENING_PRELOAD_BRANCHES=12
CHESS_OPENING_PRELOAD_DELAY_MS=60
# CHESS_OPENING_CACHE_PATH=

# Optional MinoMuncher replay upload limit.
MINOMUNCHER_REPLAY_MAX_BYTES=26214400

# Optional VM status dashboard.
# Create a private status channel, copy its channel ID, and set it here.
VM_STATUS_CHANNEL_ID=
VM_STATUS_MESSAGE_ID=
VM_STATUS_INTERVAL_MS=5000
VM_STATUS_DISK_PATH=/
